<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Let WinUI 3 / Mica handle the sidebar background — use theme brush -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush"
                     Color="{ThemeResource SystemChromeMediumLowColor}"
                     Opacity="0.6" />
    <SolidColorBrush x:Key="SidebarBorderBrush"
                     Color="{ThemeResource SystemChromeDisabledLowColor}" />
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#0C0C0F" />
    <SolidColorBrush x:Key="AccentBrush"             Color="{ThemeResource SystemAccentColor}" />

</ResourceDictionary>
