<Application
    x:Class="wmux.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:wmux.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:ColorIndexToBrushConverter x:Key="ColorIndexToBrushConverter" />
            <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <helpers:NullToInverseVisibilityConverter x:Key="NullToInverseVisibilityConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:TimeAgoConverter x:Key="TimeAgoConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
