<UserControl
    x:Class="wmux.Views.NotificationsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:wmux.Models">

    <Border Background="#0D0D0D" BorderBrush="#1E1E1E" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" Padding="16,14,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Notifications" FontSize="13" FontWeight="SemiBold" />
                <Button Grid.Column="1" Click="OnClose" Style="{StaticResource IconButtonStyle}">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>

            <!-- Notification list -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{x:Bind GetAllNotifications(), Mode=OneWay}" Padding="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TerminalNotification">
                            <Border Padding="12,10" Margin="0,2" CornerRadius="8"
                                    Background="#141414">
                                <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{x:Bind Title}" FontSize="12"
                                                   FontWeight="Medium" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind CreatedAt, Converter={StaticResource TimeAgoConverter}}"
                                                   FontSize="10" Foreground="#555" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind Body}" FontSize="11"
                                               Foreground="#888" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Clear all -->
            <Button Grid.Row="2" HorizontalAlignment="Stretch" Margin="8,8"
                    Click="OnClearAll" Content="Clear all" />
        </Grid>
    </Border>
</UserControl>
