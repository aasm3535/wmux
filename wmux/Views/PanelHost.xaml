<UserControl
    x:Class="wmux.Views.PanelHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:wmux.Models"
    xmlns:views="using:wmux.Views">

    <!--
        PanelHost renders a single panel or a split pair recursively.
        For now: renders the first panel. SplitController will extend this
        into a full binary-tree split layout (like bonsplit in cmux).
    -->
    <Grid x:Name="RootGrid" />
</UserControl>
