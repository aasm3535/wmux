<UserControl
    x:Class="wmux.Views.WorkspaceContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Empty state -->
        <StackPanel x:Name="EmptyState"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="8">
            <TextBlock Text="wmux"
                       FontSize="28" FontWeight="Light"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Ctrl+T — new workspace"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Active workspace host — populated from code-behind -->
        <ContentPresenter x:Name="WorkspaceHost" />
    </Grid>
</UserControl>
