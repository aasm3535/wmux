<UserControl
    x:Class="wmux.Views.WorkspaceContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:wmux.Models"
    xmlns:views="using:wmux.Views"
    xmlns:vm="using:wmux.ViewModels">

    <Grid>
        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.SelectedWorkspace, Mode=OneWay, Converter={StaticResource NullToInverseVisibilityConverter}}">
            <TextBlock Text="wmux" FontSize="32" FontWeight="Light" Foreground="#333"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Ctrl+T  —  new workspace" FontSize="12" Foreground="#444"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Active workspace panels -->
        <ContentPresenter Content="{x:Bind ViewModel.SelectedWorkspace, Mode=OneWay}">
            <ContentPresenter.ContentTemplate>
                <DataTemplate x:DataType="models:Workspace">
                    <!-- Single panel (split layout will be added as SplitController) -->
                    <views:PanelHost Workspace="{x:Bind}" />
                </DataTemplate>
            </ContentPresenter.ContentTemplate>
        </ContentPresenter>
    </Grid>
</UserControl>
