<UserControl
    x:Class="wmux.Views.BrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">

        <!-- Address bar -->
        <Grid Grid.Row="0" Padding="8,6" Background="#0A0A0A" ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" Click="OnBack" Style="{StaticResource IconButtonStyle}"
                    x:Name="BackButton">
                <FontIcon Glyph="&#xE72B;" FontSize="13" />
            </Button>

            <TextBox Grid.Column="1" x:Name="AddressBar"
                     PlaceholderText="Enter URL..."
                     Margin="4,0"
                     KeyDown="OnAddressKeyDown"
                     VerticalAlignment="Center" />

            <Button Grid.Column="2" Click="OnRefresh" Style="{StaticResource IconButtonStyle}">
                <FontIcon Glyph="&#xE72C;" FontSize="13" />
            </Button>

            <Button Grid.Column="3" Click="OnOpenInBrowser" Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="Open in system browser">
                <FontIcon Glyph="&#xE774;" FontSize="13" />
            </Button>
        </Grid>

        <!-- WebView2 browser -->
        <WebView2 Grid.Row="1" x:Name="BrowserWebView"
                  NavigationStarting="OnNavigationStarting"
                  NavigationCompleted="OnNavigationCompleted" />
    </Grid>
</UserControl>
