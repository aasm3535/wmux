<UserControl
    x:Class="wmux.Views.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:wmux.Models"
    xmlns:vm="using:wmux.ViewModels">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Padding="16,12,10,8">
            <TextBlock Text="wmux"
                       FontSize="12" FontWeight="SemiBold"
                       CharacterSpacing="100"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <Button Command="{x:Bind ViewModel.NewWorkspaceCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="New workspace  Ctrl+T">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </Grid>

        <!-- ── Workspace list ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Workspaces, Mode=OneWay}"
                          Padding="8,2,8,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Workspace">
                        <Grid x:Name="ItemRoot" Margin="0,1,0,1">
                            <!-- Main tab button -->
                            <Button Style="{StaticResource WorkspaceTabStyle}"
                                    Click="OnWorkspaceClick" Tag="{x:Bind}">
                                <!-- Leave room for close btn on the right -->
                                <Grid ColumnDefinitions="14,*,28" ColumnSpacing="6">

                                    <!-- Color dot -->
                                    <Ellipse Grid.Column="0"
                                             Width="7" Height="7"
                                             VerticalAlignment="Center"
                                             Fill="{x:Bind ColorIndex, Converter={StaticResource ColorIndexToBrushConverter}}" />

                                    <!-- Name + meta -->
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{x:Bind GitBranch, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="{x:Bind GitBranch, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind LatestNotificationText, Mode=OneWay}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemAccentColorLight1}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{x:Bind LatestNotificationText, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                                    </StackPanel>

                                    <!-- Badge / placeholder (hidden when no unread) -->
                                    <InfoBadge Grid.Column="2"
                                               Value="{x:Bind TotalUnreadCount, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Visibility="{x:Bind HasUnreadNotifications, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Button>

                            <!-- Close (×) button — always visible at right -->
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0"
                                    Width="22" Height="22"
                                    Padding="0"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnCloseWorkspace"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="Close workspace"
                                    Opacity="0.5">
                                <FontIcon Glyph="&#xE711;" FontSize="10" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Bottom toolbar ── -->
        <Grid Grid.Row="2" Padding="8,4,8,12">
            <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Left">
                <Button Command="{x:Bind ViewModel.SplitVerticalCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Split vertical">
                    <FontIcon Glyph="&#xE94E;" FontSize="13" />
                </Button>
                <Button Command="{x:Bind ViewModel.SplitHorizontalCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Split horizontal">
                    <FontIcon Glyph="&#xE94F;" FontSize="13" />
                </Button>
            </StackPanel>

            <Button Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="OnNotificationsBellClick"
                    ToolTipService.ToolTip="Notifications">
                <FontIcon Glyph="&#xEA8F;" FontSize="13" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
