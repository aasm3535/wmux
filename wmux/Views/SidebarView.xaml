<UserControl
    x:Class="wmux.Views.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:wmux.Models">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Logo / Header ── -->
        <Grid Grid.Row="0" Padding="16,16,12,12">
            <TextBlock Text="wmux"
                       FontSize="14" FontWeight="SemiBold"
                       CharacterSpacing="50"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <Button Command="{x:Bind ViewModel.NewWorkspaceCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="New workspace  Ctrl+T">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </Grid>

        <!-- ── Workspace tabs ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Workspaces, Mode=OneWay}"
                          Padding="8,0,8,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Workspace">
                        <Grid Margin="0,2,0,0">
                            <!-- Tab button -->
                            <Button Style="{StaticResource WorkspaceTabStyle}"
                                    Click="OnWorkspaceClick" Tag="{x:Bind}">
                                <Grid ColumnDefinitions="10,*,24" ColumnSpacing="10">

                                    <!-- Color dot -->
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             VerticalAlignment="Center"
                                             Fill="{x:Bind ColorIndex, Converter={StaticResource ColorIndexToBrushConverter}}" />

                                    <!-- Name + meta -->
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    Visibility="{x:Bind GitBranch, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                            <TextBlock FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis">
                                                <Run Text="&#xE7B2; " FontFamily="Segoe MDL2 Assets" FontSize="9" />
                                                <Run Text="{x:Bind GitBranch, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind LatestNotificationText, Mode=OneWay}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemAccentColorLight1}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{x:Bind LatestNotificationText, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                                    </StackPanel>

                                    <!-- Badge -->
                                    <InfoBadge Grid.Column="2"
                                               Value="{x:Bind TotalUnreadCount, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind HasUnreadNotifications, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Button>

                            <!-- Close × -->
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    Width="20" Height="20" Padding="0"
                                    CornerRadius="4"
                                    Background="Transparent" BorderThickness="0"
                                    Click="OnCloseWorkspace" Tag="{x:Bind}"
                                    Opacity="0.6"
                                    ToolTipService.ToolTip="Close">
                                <FontIcon Glyph="&#xE711;" FontSize="9" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Bottom toolbar ── -->
        <Grid Grid.Row="2" Padding="10,6,10,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Left">
                <Button Command="{x:Bind ViewModel.SplitVerticalCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Split vertical">
                    <FontIcon Glyph="&#xE94E;" FontSize="13" />
                </Button>
                <Button Command="{x:Bind ViewModel.SplitHorizontalCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Split horizontal">
                    <FontIcon Glyph="&#xE94F;" FontSize="13" />
                </Button>
            </StackPanel>

            <Button Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="OnNotificationsBellClick"
                    ToolTipService.ToolTip="Notifications">
                <FontIcon Glyph="&#xEA8F;" FontSize="13" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
