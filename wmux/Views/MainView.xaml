<UserControl
    x:Class="wmux.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:wmux.Views"
    xmlns:vm="using:wmux.ViewModels">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="200" MinWidth="160" MaxWidth="280" />
            <!-- Separator -->
            <ColumnDefinition Width="1" />
            <!-- Terminal area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <views:SidebarView
            Grid.Column="0"
            ViewModel="{x:Bind ViewModel}"
            Background="{StaticResource SidebarBackgroundBrush}" />

        <!-- Separator — 1px dark line -->
        <Border Grid.Column="1"
                Width="1"
                Background="{StaticResource SidebarBorderBrush}" />

        <!-- Main terminal / browser area -->
        <views:WorkspaceContentView
            Grid.Column="2"
            ViewModel="{x:Bind ViewModel}"
            Background="{StaticResource TerminalBackgroundBrush}" />

        <!-- Notification slide-in panel (overlays from right) -->
        <views:NotificationsPanel
            Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Width="320"
            ViewModel="{x:Bind ViewModel}"
            Visibility="{x:Bind ViewModel.IsNotificationPanelOpen, Mode=OneWay}" />
    </Grid>
</UserControl>
