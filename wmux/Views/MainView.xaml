<UserControl
    x:Class="wmux.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:wmux.Views"
    xmlns:vm="using:wmux.ViewModels">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220" MinWidth="160" MaxWidth="360" />
            <!-- Drag handle — 5px invisible hit area -->
            <ColumnDefinition Width="5" />
            <!-- Terminal -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <views:SidebarView
            Grid.Column="0"
            ViewModel="{x:Bind ViewModel}"
            Background="{ThemeResource NavigationViewDefaultPaneBackground}" />

        <!-- Resize handle — drag to resize sidebar -->
        <Border Grid.Column="1"
                x:Name="ResizeHandle"
                Background="Transparent"
                PointerEntered="OnResizeEnter"
                PointerExited="OnResizeExit"
                PointerPressed="OnResizePressed"
                PointerMoved="OnResizeMoved"
                PointerReleased="OnResizeReleased">
            <!-- Visible 1px line in center -->
            <Border Width="1"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
        </Border>

        <!-- Terminal area -->
        <views:WorkspaceContentView
            Grid.Column="2"
            ViewModel="{x:Bind ViewModel}"
            Background="#0C0C0C" />

        <!-- Notifications modal overlay -->
        <views:NotificationsPanel
            Grid.Column="0" Grid.ColumnSpan="3"
            ViewModel="{x:Bind ViewModel}"
            Visibility="{x:Bind ViewModel.IsNotificationPanelOpen, Mode=OneWay}" />
    </Grid>
</UserControl>
